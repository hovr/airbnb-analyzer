{
  "manifest_version": 3,
  "name": "Airbnb Wishlist Analyzer",
  "version": "1.0",
  "description": "Extract property details and reviews from Airbnb wishlists for LLM analysis",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.airbnb.co.uk/*",
    "https://www.airbnb.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.airbnb.co.uk/wishlists/*",
        "https://www.airbnb.com/wishlists/*"
      ],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}